# Copy this file to .env.local and fill in your values

# Supabase project URL — use your hosted project (NOT 127.0.0.1 for production)
# Find it at: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase publishable (anon) key — safe to expose in frontend
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key-here"

# Optional: Razorpay public key (returned by edge function, but can set here for reference)
# VITE_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
#
# IMPORTANT: Set the following secrets in Supabase Dashboard → Project Settings → Edge Functions → Secrets:
#   RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
#   RAZORPAY_KEY_SECRET=your_razorpay_secret_key

